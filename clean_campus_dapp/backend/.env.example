PORT=3001
DATABASE_URL=sqlite:./database.db

# ========== 链切换：ACTIVE_CHAIN=sepolia 或 hardhat ==========
ACTIVE_CHAIN=sepolia

# Sepolia 测试网（当 ACTIVE_CHAIN=sepolia 时使用）
SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
SEPOLIA_CONTRACT_ADDRESS=0x你的Sepolia合约地址
# 可选
SEPOLIA_BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

# Hardhat 本地链（当 ACTIVE_CHAIN=hardhat 时使用，需先 npx hardhat node 再 npm run deploy）
HARDHAT_RPC_URL=http://localhost:8545
HARDHAT_CONTRACT_ADDRESS=0x你的本地合约地址

# 兼容旧配置：未设置 SEPOLIA_* / HARDHAT_* 时，会回退使用下面的 CONTRACT_ADDRESS 与 RPC_URL
# CONTRACT_ADDRESS=0x...
# RPC_URL=https://...

ADMIN_PRIVATE_KEY=你的管理员私钥
BLOCK_EXPLORER_URL=https://sepolia.etherscan.io

PINATA_API_KEY=
PINATA_SECRET_KEY=
